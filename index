<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Heroes, Interlopers — Gotta Do More</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Mono:wght@300;400;500&display=swap');

  :root {
    --ink: #0d0d0d;
    --paper: #F5CDC1;
    --amber: #b87008;
    --violet: #4a2d6e;
    --smoke: #6a5a48;
    --red: #8c2020;
    --rule-bg: var(--paper);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'DM Mono', monospace;
    font-weight: 300;
  }

  /* === NAV === */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 48px;
    border-bottom: 1px solid rgba(13,13,13,0.12);
    background: rgba(240,232,216,0.9);
    backdrop-filter: blur(8px);
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-style: italic;
    letter-spacing: 0.05em;
    color: var(--ink);
  }

  .nav-links {
    display: flex;
    gap: 36px;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .nav-links a {
    color: var(--smoke);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--amber); }

  /* === HERO === */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    border-bottom: 1px solid rgba(13,13,13,0.12);
    overflow: hidden;
  }

  /* Left: text panel */
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: first-baseline;
    padding: 120px 48px 80px;
    position: relative;
    z-index: 2;
  }

  /* Animated grid background — faint, on left panel only */
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .grid-layer {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: repeat(10, 1fr);
    gap: 2px;
    opacity: 0.07;
  }

  .grid-cell {
    transition: background 1s ease;
  }

  /* Right: album art panel */
  .hero-right {
    position: relative;
    overflow: hidden;
    background: var(--ink);
  }

  .album-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0;
    animation: fadeUp 1.2s ease 0.6s forwards;
  }

  .edition-tag {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid var(--amber);
    padding: 4px 10px;
    margin-bottom: 36px;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3.5rem, 7vw, 8rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: var(--ink);
    animation: fadeUp 1.2s ease forwards;
    opacity: 0;
  }

  .hero-title em {
    font-style: italic;
    color: var(--amber);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.4rem);
    font-family: 'Playfair Display', serif;
    font-style: italic;
    color: var(--smoke);
    animation: fadeUp 1.4s ease 0.2s forwards;
    opacity: 0;
    padding-bottom: 20px
  }

  /* Running rule */
  .rule {
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--amber), transparent);
    margin: 60px 0;
    position: relative;
  }
  .rule::after {
    content: attr(data-text);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--paper);
    padding: 0 16px;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--amber);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* === COLUMNS SECTION === */
  .columns-section {
    padding: 80px 48px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    border-bottom: 1px solid rgba(13,13,13,0.1);
    background: var(--paper);
  }

  .col-header {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--amber);
  }

  .col-body {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--smoke);
  }

  .col-body p + p { margin-top: 1em; }

  .col-body strong {
    color: var(--ink);
    font-weight: 500;
  }

  .pull-quote {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-style: italic;
    line-height: 1.4;
    color: var(--ink);
    border-left: 3px solid var(--amber);
    padding-left: 24px;
    margin: 32px 0;
  }

  /* === TRACKLIST === */
  .tracklist-section {
    padding: 80px 48px;
    border-bottom: 1px solid rgba(13,13,13,0.1);
    background: var(--paper);
  }

  .tracklist-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--ink);
  }

  .tracklist-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--ink);
  }

  .tracklist-count {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--smoke);
  }

  .track-row {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    align-items: center;
    padding: 18px 0;
    border-bottom: 1px solid rgba(13,13,13,0.08);
    transition: all 0.2s;
    cursor: default;
  }
  .track-row:hover {
    padding-left: 12px;
    border-bottom-color: rgba(184,112,8,0.5);
    background: rgba(184,112,8,0.04);
  }
  .track-row:hover .track-num-r { color: var(--amber); }

  .track-num-r {
    font-size: 0.65rem;
    color: var(--violet);
    letter-spacing: 0.1em;
    transition: color 0.2s;
  }

  .track-name-r {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: var(--ink);
  }

  .track-suite {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--smoke);
    text-transform: uppercase;
  }

  /* Prairie Suite highlight */
  .track-row.suite {
    padding-left: 20px;
    border-left: 2px solid var(--violet);
  }

  /* === BOTTOM === */
  .bottom-strip {
    height: 6px;
    background: linear-gradient(to right, var(--violet), var(--amber), var(--red), var(--amber), var(--violet));
  }

  .footer-section {
    padding: 60px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
    border-top: 1px solid rgba(13,13,13,0.1);
    background: var(--paper);
  }

  .footer-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-style: italic;
    margin-bottom: 8px;
    color: var(--ink);
  }

  .footer-album {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
  }

  .footer-links-v {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .footer-links-v a {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--smoke);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links-v a:hover { color: var(--ink); }

  .footer-copy-text {
    font-size: 0.65rem;
    color: rgba(13,13,13,0.35);
    line-height: 1.8;
    margin-top: auto;
  }

  /* === RESPONSIVE === */
  @media (max-width: 900px) {
    nav { padding: 16px 24px; }
    .hero { grid-template-columns: 1fr; }
    .hero-left { padding: 100px 24px 60px; }
    .hero-right { height: 60vw; min-height: 300px; }
    .columns-section { grid-template-columns: 1fr; padding: 60px 24px; }
    .tracklist-section { padding: 60px 24px; }
    .footer-section { grid-template-columns: 1fr; padding: 40px 24px; }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">heroes, interlopers</div>
  <div class="nav-links">
    <a href="#about">About</a>
    <a href="#tracks">Tracks</a>
    <a href="#">Listen</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-bg">
      <div class="grid-layer" id="heroGrid"></div>
    </div>
    <!--<div class="edition-tag">New Album · 2026</div> --->
    <h1 class="hero-title"><em>Gotta Do</em><br>More</h1>
    <p class="hero-sub">the debut album from heroes, interlopers</p>
    <p> Dan Galat - violin</p>
    <p> Scott Rubin - viola</p>
    <p> Kelly Quesada - cello</p>
    <p> Ben Willis - contrabass</p>
  </div>
  <div class="hero-right">
    <img class="album-cover-img" src="img/front_cover.jpg" alt="Gotta Do More — Heroes, Interlopers album cover">
  </div>
</section>

<div class="rule" data-text="About the Record"></div>

<!-- COLUMNS -->
<section class="columns-section" id="about">
  <div>
    <div class="col-header">The Record</div>
    <div class="col-body">
      <p><strong>Gotta Do More</strong> arrives like a field at the edge of a city — sprawling, wild, and shot through with color that doesn't apologize for itself.</p>
      <p>Heroes, Interlopers built this album from fragments: torn photographs, typewritten lists, woven grids of blue tape and prairie grass. The textures of the cover are the textures of the music.</p>
      <div class="pull-quote">"Built from collage and contradiction."</div>
      <p>The record opens with politics and pleasure, threads a string quartet through its center, and closes with five movements of the Prairie School suite — lake dance, fire, fireflies, coda.</p>
    </div>
  </div>
  <div>
    <div class="col-header">Collaborators</div>
    <div class="col-body">
      <p><strong>Bill Harris</strong> appears on Track 5, "Free with Bill," lending the record one of its most open moments — a conversation rather than a performance.</p>
    </div>
  </div>
</section>

<!-- TRACKLIST -->
<section class="tracklist-section" id="tracks">
  <div class="tracklist-header">
    <h2 class="tracklist-title">Track Listing</h2>
    <span class="tracklist-count">13 tracks</span>
  </div>

  <div class="track-row"><span class="track-num-r">01</span><span class="track-name-r">Pleasure, Politics (Take 2)</span><span class="track-suite"></span></div>
  <div class="track-row"><span class="track-num-r">02</span><span class="track-name-r">Having</span><span class="track-suite"></span></div>
  <div class="track-row"><span class="track-num-r">03</span><span class="track-name-r">String Quartet #1</span><span class="track-suite"></span></div>
  <div class="track-row"><span class="track-num-r">04</span><span class="track-name-r">Building, Work</span><span class="track-suite"></span></div>
  <div class="track-row"><span class="track-num-r">05</span><span class="track-name-r">Free with Bill <em style="font-size:0.85em;color:var(--smoke);font-style:italic;">(feat. Bill Harris)</em></span><span class="track-suite"></span></div>
  <div class="track-row"><span class="track-num-r">06</span><span class="track-name-r">Keeping</span><span class="track-suite"></span></div>
  <div class="track-row"><span class="track-num-r">07</span><span class="track-name-r">Pleasure, Politics</span><span class="track-suite"></span></div>
  <div class="track-row"><span class="track-num-r">08</span><span class="track-name-r">String Quartet #1 (reprise)</span><span class="track-suite"></span></div>
  <div class="track-row suite"><span class="track-num-r">09</span><span class="track-name-r">Prairie School — prairie school</span><span class="track-suite">Suite I</span></div>
  <div class="track-row suite"><span class="track-num-r">10</span><span class="track-name-r">Prairie School — lake dance</span><span class="track-suite">Suite II</span></div>
  <div class="track-row suite"><span class="track-num-r">11</span><span class="track-name-r">Prairie School — prairie fire</span><span class="track-suite">Suite III</span></div>
  <div class="track-row suite"><span class="track-num-r">12</span><span class="track-name-r">Prairie School — firefly fields</span><span class="track-suite">Suite IV</span></div>
  <div class="track-row suite"><span class="track-num-r">13</span><span class="track-name-r">Prairie School — coda</span><span class="track-suite">Suite V</span></div>
</section>

<div class="bottom-strip"></div>

<!-- FOOTER -->
<footer class="footer-section">
  <div>
    <div class="footer-title">heroes,<br>interlopers</div>
    <div class="footer-album">Gotta Do More · 2025</div>
  </div>
  <div class="footer-links-v">
    <a href="#">Bandcamp</a>
    <a href="#">Spotify</a>
    <a href="#">Apple Music</a>
    <a href="#">Instagram</a>
    <a href="#">Press Contact</a>
  </div>
  <div>
    <div class="footer-copy-text">© 2025 Heroes, Interlopers.<br>All rights reserved.<br>Artwork by the band.</div>
  </div>
</footer>

<script>
  // Animate grid cells — softer palette for light background
  const grid = document.getElementById('heroGrid');
  const colors = [
    '#c47a1a','#d49030','#2a4a7a','#4a6a9a','#4a6a2a','#6b3f8a','#d0c0a0','#9a8a60'
  ];
  
  for (let i = 0; i < 120; i++) {
    const cell = document.createElement('div');
    cell.className = 'grid-cell';
    cell.style.background = colors[Math.floor(Math.random() * colors.length)];
    grid.appendChild(cell);
  }

  // Animate cells
  setInterval(() => {
    const cells = grid.querySelectorAll('.grid-cell');
    const idx = Math.floor(Math.random() * cells.length);
    cells[idx].style.background = colors[Math.floor(Math.random() * colors.length)];
  }, 300);
</script>
</body>
</html>
